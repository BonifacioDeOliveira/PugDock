{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PugDock",
  "version": "0.1.0",
  "identifier": "com.pugdock.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "PugDock",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZEMUVFRDFENTRGOUIyOEUKUldTT3N2bFVIZTBlYmVuWkhQaTRFdlkyRnZLZ3dpOS9lRnpzQUJWZktDcGg0bzB4R3ROc3FYWTAK",
      "endpoints": [
        "https://github.com/BonifacioDeOliveira/PugDock/releases/latest/download/latest.json"
      ]
    }
  }
}